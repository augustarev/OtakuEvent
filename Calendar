    <script>
        // Tailwind script
        function initTailwind() {
            tailwind.config = {
                content: [],
                theme: {
                    extend: {}
                }
            }
        }

        // Calendar data for April 2026 (April 1 is Wednesday)
        let currentMonth = 4
        let currentYear = 2026
        
        // Events with unique IDs for drag & drop
        let events = [
            { id: 1, date: "2026-04-04", title: "Weekend Market", time: "9 AM", category: "personal", color: "#00d4ff", duration: "4h" },
            { id: 2, date: "2026-04-12", title: "Team Strategy Meeting", time: "10 AM", category: "work", color: "#00a3cc", duration: "2h" },
            { id: 3, date: "2026-04-15", title: "Doctor Appointment", time: "2 PM", category: "health", color: "#22c55e", duration: "1h" },
            { id: 4, date: "2026-04-25", title: "Project Deadline", time: "11:59 PM", category: "work", color: "#f59e0b", duration: "—" },
            { id: 5, date: "2026-04-11", title: "Today", time: "", category: "personal", color: "#00d4ff", duration: "" }
        ]

        let nextEventId = 6

        // Render calendar with draggable events
        function renderCalendar() {
            const grid = document.getElementById('calendar-grid')
            grid.innerHTML = ''
            
            // April 2026 starts on Wednesday (index 2 if Mon=0)
            const firstDay = 2
            const daysInMonth = 30
            
            // Previous month padding
            for (let i = 0; i < firstDay; i++) {
                const empty = document.createElement('div')
                empty.className = 'day-cell opacity-30'
                empty.innerHTML = `<div class="text-xs text-white/30">31</div>`
                grid.appendChild(empty)
            }
            
            // Actual days
            for (let day = 1; day <= daysInMonth; day++) {
                const dateStr = `\( {currentYear}-0 \){currentMonth}-` + (day < 10 ? '0' : '') + day
                
                const cell = document.createElement('div')
                cell.className = `day-cell hover:ring-2 hover:ring-cyan-400/50 flex flex-col`
                cell.dataset.date = dateStr
                
                if (day === 11) cell.classList.add('today')
                
                // Day header
                let html = `
                    <div class="flex justify-between items-center text-xs mb-2">
                        <span class="\( {day === 11 ? 'text-cyan-400 font-semibold' : ''}"> \){day}</span>
                `
                const dayEvents = events.filter(e => e.date === dateStr)
                if (dayEvents.length) {
                    html += `<span class="px-2 py-px text-[10px] bg-white/10 rounded-full">\( {dayEvents.length} event \){dayEvents.length > 1 ? 's' : ''}</span>`
                }
                html += `</div>`
                
                // Draggable event items
                dayEvents.forEach(ev => {
                    html += `
                    <div class="event-item" draggable="true" data-event-id="${ev.id}">
                        <span class="dot" style="color: ${ev.color}">●</span>
                        <span class="flex-1 truncate font-medium">${ev.title}</span>
                        \( {ev.time ? `<span class="text-xs text-white/50 whitespace-nowrap"> \){ev.time}</span>` : ''}
                    </div>`
                })
                
                cell.innerHTML = html
                
                // Click to view details
                cell.onclick = (e) => {
                    // Don't trigger if clicking on an event (which is draggable)
                    if (!e.target.closest('.event-item')) {
                        showDayDetail(dateStr, dayEvents)
                    }
                }
                
                // === DRAG & DROP SUPPORT ===
                // Make cell a drop target
                cell.ondragover = (e) => {
                    e.preventDefault()
                    cell.classList.add('dragover')
                }
                cell.ondragleave = () => {
                    cell.classList.remove('dragover')
                }
                cell.ondrop = (e) => {
                    e.preventDefault()
                    cell.classList.remove('dragover')
                    
                    const eventId = parseInt(e.dataTransfer.getData('text/plain'))
                    const event = events.find(ev => ev.id === eventId)
                    
                    if (event && event.date !== dateStr) {
                        // Move the event
                        event.date = dateStr
                        renderCalendar()
                        
                        // Toast feedback
                        showToast(`✅ Moved "${event.title}" to ${day} April`)
                    }
                }
                
                // Attach drag listeners to every event inside this cell
                // (listeners are added after innerHTML is set)
                setTimeout(() => {
                    const eventElements = cell.querySelectorAll('.event-item')
                    eventElements.forEach(el => {
                        el.ondragstart = (e) => {
                            e.dataTransfer.setData('text/plain', el.dataset.eventId)
                            // Optional visual feedback
                            setTimeout(() => {
                                el.style.opacity = '0.4'
                            }, 0)
                        }
                        el.ondragend = () => {
                            // Reset opacity
                            el.style.opacity = '1'
                        }
                    })
                }, 10)
                
                grid.appendChild(cell)
            }
            
            // Next month padding
            const remaining = 35 - (firstDay + daysInMonth)
            for (let i = 0; i < remaining; i++) {
                const empty = document.createElement('div')
                empty.className = 'day-cell opacity-30'
                empty.innerHTML = `<div class="text-xs text-white/30">${i+1}</div>`
                grid.appendChild(empty)
            }
        }

        // Charts (unchanged - static for demo)
        let weeklyChartInstance, categoryChartInstance, energyChartInstance

        function createCharts() {
            const weeklyCtx = document.getElementById('weeklyChart')
            if (weeklyChartInstance) weeklyChartInstance.destroy()
            weeklyChartInstance = new Chart(weeklyCtx, {
                type: 'bar',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Hours',
                        data: [7.5, 8.2, 6.0, 7.8, 9.1, 4.5, 5.2],
                        backgroundColor: '#00d4ff',
                        borderColor: '#00d4ff',
                        borderWidth: 2,
                        borderRadius: 6,
                        barThickness: 28
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { grid: { color: '#334155' }, ticks: { color: '#64748b', font: { size: 11 } } },
                        x: { grid: { color: '#334155' }, ticks: { color: '#64748b', font: { size: 12 } } }
                    }
                }
            })

            const categoryCtx = document.getElementById('categoryChart')
            if (categoryChartInstance) categoryChartInstance.destroy()
            categoryChartInstance = new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Work', 'Personal', 'Health', 'Other'],
                    datasets: [{
                        data: [48, 32, 12, 8],
                        backgroundColor: ['#00d4ff', '#22c55e', '#a855f7', '#f59e0b'],
                        borderWidth: 0,
                        cutout: '78%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: { backgroundColor: '#0a1428', titleColor: '#fff', bodyColor: '#fff' }
                    }
                }
            })

            const energyCtx = document.getElementById('energyChart')
            if (energyChartInstance) energyChartInstance.destroy()
            energyChartInstance = new Chart(energyCtx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Focus Level',
                        data: [62, 78, 85, 71, 88, 95, 91],
                        borderColor: '#00d4ff',
                        backgroundColor: 'rgba(0, 212, 255, 0.15)',
                        tension: 0.4,
                        borderWidth: 4,
                        pointRadius: 5,
                        pointBackgroundColor: '#fff',
                        pointBorderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { min: 0, max: 100, grid: { color: '#334155' }, ticks: { color: '#64748b', stepSize: 20 } },
                        x: { grid: { color: '#334155' }, ticks: { color: '#64748b' } }
                    }
                }
            })
        }

        // Tab switching (demo)
        function switchTab(n) {
            const tabs = document.querySelectorAll('nav a')
            tabs.forEach((t, i) => {
                if (i === n) {
                    t.classList.add('text-cyan-400', 'border-b-2', 'border-cyan-400')
                } else {
                    t.classList.remove('text-cyan-400', 'border-b-2', 'border-cyan-400')
                }
            })
            if (n !== 1) {
                alert("🚀 This is a fully functional demo. In the real ChartCal app this would load the " + ["Dashboard", "Calendar", "Insights", "Reports", "Settings"][n] + " page!")
            }
        }

        // Improved filter using dataset.date
        let activeFilter = 'all'
        function filterCategory(cat) {
            activeFilter = cat
            const cells = document.querySelectorAll('.day-cell')
            
            cells.forEach(cell => {
                if (cat === 'all') {
                    cell.style.opacity = 1
                    return
                }
                
                const dateStr = cell.dataset.date
                const hasMatch = events.some(e => e.date === dateStr && e.category === cat)
                cell.style.opacity = hasMatch ? 1 : 0.3
            })
            
            // Toggle active class
            document.querySelectorAll('button[id^="filter-"]').forEach(b => {
                b.classList.remove('active', 'bg-cyan-400', 'text-black')
            })
            document.getElementById('filter-' + cat).classList.add('active', 'bg-cyan-400', 'text-black')
        }

        function showDayDetail(dateStr, dayEvents) {
            if (!dayEvents || !dayEvents.length) {
                alert(`📅 ${dateStr}\n\nNo events scheduled.\n\nDrag existing events here or use Quick Add!`)
                return
            }
            let msg = `📅 ${dateStr}\n\n`
            dayEvents.forEach(ev => {
                msg += `• ${ev.title} \( {ev.time ? `( \){ev.time})` : ''} — ${ev.duration}\n`
            })
            alert(msg + "\n\n💡 Tip: You can drag this event to any other day!")
        }

        function showQuickAdd() {
            document.getElementById('quick-modal').classList.remove('hidden')
            document.getElementById('quick-modal').classList.add('flex')
        }
        
        function hideQuickAdd() {
            const modal = document.getElementById('quick-modal')
            modal.classList.add('hidden')
            modal.classList.remove('flex')
        }
        
        function selectCategory(btn) {
            document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active', 'bg-cyan-400', 'text-black'))
            btn.classList.add('active', 'bg-cyan-400', 'text-black')
        }
        
        function addEventFromModal() {
            const title = document.getElementById('modal-title').value || "Untitled Event"
            const date = document.getElementById('modal-date').value
            const time = document.getElementById('modal-time').value || ""
            
            hideQuickAdd()
            
            // Add new event with unique ID
            const newEvent = {
                id: nextEventId++,
                date: date,
                title: title,
                time: time,
                category: "work",
                color: "#00d4ff",
                duration: "1h"
            }
            events.push(newEvent)
            
            renderCalendar()
            
            showToast(`✅ New event "${title}" added!`)
        }
        
        function prevMonth() {
            if (currentMonth === 1) { currentMonth = 12; currentYear-- } else currentMonth--
            document.getElementById('month-title').textContent = `${new Date(currentYear, currentMonth-1).toLocaleString('default', { month: 'long' })} ${currentYear}`
            renderCalendar()
        }
        
        function nextMonth() {
            if (currentMonth === 12) { currentMonth = 1; currentYear++ } else currentMonth++
            document.getElementById('month-title').textContent = `${new Date(currentYear, currentMonth-1).toLocaleString('default', { month: 'long' })} ${currentYear}`
            renderCalendar()
        }
        
        function goToToday() {
            currentMonth = 4
            currentYear = 2026
            document.getElementById('month-title').textContent = `April 2026`
            renderCalendar()
        }
        
        // Toast notification helper
        function showToast(message) {
            const toast = document.createElement('div')
            toast.style.cssText = 'position:fixed; bottom:30px; right:30px; background:#00d4ff; color:#000; padding:16px 24px; border-radius:9999px; font-weight:600; box-shadow:0 10px 15px -3px rgb(0 212 255); z-index:99999;'
            toast.textContent = message
            document.body.appendChild(toast)
            setTimeout(() => toast.remove(), 2500)
        }
        
        // Demo explanation tooltip
        function explainDragDrop() {
            showToast("🖱️ Drag any event pill to another day • Drop to move instantly!")
        }

        // Initialize everything
        window.onload = function() {
            initTailwind()
            renderCalendar()
            createCharts()
            
            console.log('%c✅ ChartCal demo with DRAG & DROP loaded!', 'color:#00d4ff; font-size:15px; font-weight:600')
            console.log('%c📅 Drag any colored event to another date in the calendar. Events update live!', 'background:#0a1428;color:#00d4ff;padding:2px 6px;border-radius:4px')
        }
    </script>
</body>
</html>